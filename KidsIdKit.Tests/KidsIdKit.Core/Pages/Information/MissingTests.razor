@using global::KidsIdKit.Core.SharedComponents;
@using Moq;

@inherits TestContext

@code
{
    private readonly Mock<IPageState> _mockPageState;

    public MissingTests()
    {
        _mockPageState = new Mock<IPageState>();
        Services.AddSingleton(_mockPageState.Object);
        JSInterop.Mode = JSRuntimeMode.Loose;
    }

    [Fact]
    public void RendersMissingPageTitleAndMainHeading()
    {
        var cut = RenderComponent<Missing>();

        Assert.Equal("Missing Child", cut.Find("ion-title").TextContent.Trim());
        Assert.Equal("In the Event of a Missing Child", cut.Find("h1").TextContent.Trim());
    }
}
