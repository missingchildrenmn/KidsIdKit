@using global::KidsIdKit.Core.SharedComponents;
@using Moq;

@inherits TestContext

@code
{
    private readonly Mock<IPageState> _mockPageState;

    public InternationalTests()
    {
        _mockPageState = new Mock<IPageState>();
        Services.AddSingleton(_mockPageState.Object);
        JSInterop.Mode = JSRuntimeMode.Loose;
    }

    [Fact]
    public void RendersInternationalTitleAndStateDepartmentContact()
    {
        var cut = RenderComponent<International>();

        Assert.Equal("International Abductions", cut.Find("ion-title").TextContent.Trim());
        Assert.Contains("Passport Issuance Alert Program", cut.Markup);
        Assert.Contains("preventabduction@state.gov", cut.Markup);
        Assert.Contains("(888) 407-4747", cut.Markup);
    }
}
