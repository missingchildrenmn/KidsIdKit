@inherits TestContext

@code
{
    [Fact]
    public void RendersDisasterPreparationTitleAndResourceLinks()
    {
        var cut = RenderComponent<DisasterPreparation>();

        Assert.Equal("Disaster Prep", cut.Find("ion-title").TextContent.Trim());

        Assert.NotNull(cut.Find("a[href='https://emergency.cdc.gov/planning/index.asp']"));
        Assert.NotNull(cut.Find("a[href='https://www.ready.gov/plan-form']"));
    }
}
