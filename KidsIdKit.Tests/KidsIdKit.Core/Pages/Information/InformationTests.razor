@using global::KidsIdKit.Core.SharedComponents;
@using Moq;

@inherits TestContext

@code
{
    private readonly Mock<IPageState> _mockPageState;

    public InformationTests()
    {
        _mockPageState = new Mock<IPageState>();
        Services.AddSingleton(_mockPageState.Object);
        JSInterop.Mode = JSRuntimeMode.Loose;
    }

    [Fact]
    public void RendersInformationPageWithExpectedLinks()
    {
        var cut = RenderComponent<Information>();

        Assert.Contains("<ion-title>Information</ion-title>", cut.Markup);

        var items = cut.FindAll("ion-item");
        Assert.Equal(9, items.Count);

        Assert.NotNull(cut.Find("ion-item[href='/Information/abduction']"));
        Assert.NotNull(cut.Find("ion-item[href='/Information/aboutmcm']"));
        Assert.NotNull(cut.Find("ion-item[href='/Information/amberalert']"));
        Assert.NotNull(cut.Find("ion-item[href='/Information/disasterpreparation']"));
        Assert.NotNull(cut.Find("ion-item[href='/Information/dna']"));
        Assert.NotNull(cut.Find("ion-item[href='/Information/international']"));
        Assert.NotNull(cut.Find("ion-item[href='/Information/missing']"));
        Assert.NotNull(cut.Find("ion-item[href='/Information/runaway']"));
        Assert.NotNull(cut.Find("ion-item[href='/Information/safety']"));
    }
}
