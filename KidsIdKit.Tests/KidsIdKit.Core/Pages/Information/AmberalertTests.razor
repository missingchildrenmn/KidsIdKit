@using global::KidsIdKit.Core.SharedComponents;
@using Moq;

@inherits TestContext

@code
{
    private readonly Mock<IPageState> _mockPageState;

    public AmberalertTests()
    {
        _mockPageState = new Mock<IPageState>();
        Services.AddSingleton(_mockPageState.Object);
        JSInterop.Mode = JSRuntimeMode.Loose;
    }

    [Fact]
    public void RendersAmberAlertTitleAndNcicLink()
    {
        var cut = RenderComponent<Amberalert>();

        Assert.Equal("AMBER Alerts", cut.Find("ion-title").TextContent.Trim());
        Assert.Contains("In Minnesota, the criteria are:", cut.Markup);

        var ncicLink = cut.Find("a[href='https://www.ojp.gov/ncjrs/virtual-library/abstracts/national-crime-information-center-ncic-investigative-tool-guide-use']");
        Assert.Contains("National Crime Information Center (NCIC)", ncicLink.TextContent);
    }
}
