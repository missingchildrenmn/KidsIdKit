@implements IDisposable
@inject IJSRuntime JSRuntime

<ion-alert id="@Id" header="@Header" message="@Message" is-open="@Show" backdrop-dismiss="false"></ion-alert>

<script>
    function setAlertEventhandler(objRef, id, confirmPrompt, cancelPrompt) {
        const alertElement = document.getElementById(id);
        let buttons = [];

        if (confirmPrompt)
        {
            buttons.push(
            {
                text: confirmPrompt,
                role: 'confirm',
            });
        }
        if (cancelPrompt)
        {
            buttons.push(
            {
                text: cancelPrompt,
                role: 'cancel',
            });
        }

        if (buttons.length == 0)
        {
            buttons.push('Action');
        }

        alertElement.buttons = buttons;

        alertElement.addEventListener('ionAlertDidDismiss', (event) => {
            try
            {
                if (event.detail.role != 'destructive') {
                    objRef.invokeMethodAsync('AlertClosedCallback', event.detail.role);
                }
            }
            catch (error)
            {
                console.error('Error invoking AlertClosedCallback:', error);
            }
        });

        alertElement.addEventListener('ionAlertDidPresent', () => {
            const alertElement = document.getElementById(id);
            alertElement.blur();
        });
    }

    function closeAlert(id) {
        try
        {
            const alertElement = document.getElementById(id);
            alertElement.dismiss('No Net Callback', 'destructive');
        }
        catch (error)
        {}
    }
</script>