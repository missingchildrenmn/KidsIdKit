@inherits LayoutComponentBase

@implements IDisposable

@using KidsIdKit.Core.Services

@inject IDataAccess dal
@inject NavigationManager navigationManager
@inject ISessionService SessionService

<ion-menu content-id="main-content">
    <ion-header>
        <ion-toolbar color="primary">
            <ion-title>Kids Id Kit</ion-title>
        </ion-toolbar>
    </ion-header>
    <ion-content class="ion-padding">
        @{
            string currentGroup = string.Empty;
        }
        @foreach (var item in menuItems.OrderBy(m => m.Group))
        {
            if (!string.IsNullOrEmpty(currentGroup) && currentGroup != item.Group)
            {
                <ion-item-divider color="secondary" style="height: 2px; min-height: 2px;"></ion-item-divider>
            }
            currentGroup = item.Group;

        <ion-menu-toggle auto-hide="false">
            <ion-item lines="none" color="@item.Color"
                @onclick="() => navigationManager.NavigateTo(item.Uri)">
                <ion-icon slot="start" name="@item.Image"></ion-icon>
                <ion-label>@item.Caption</ion-label>
            </ion-item>
        </ion-menu-toggle>
        }
    </ion-content>
</ion-menu>

@code {
    private bool collapseNavMenu = true;

    private string NavMenuCssClass => collapseNavMenu
                                        ? "collapse"
                                        : string.Empty;

    protected override Task OnInitializedAsync()
    {
        navigationManager.LocationChanged += LocationChanged;
        return base.OnInitializedAsync();
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private List<MenuItem> menuItems = new List<MenuItem>();

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        menuItems.Clear();
        if (!SessionService.IsInfoOnlyMode)
        {
            menuItems.Add(new MenuItem
                {
                    Caption = "Kids",
                    Uri = "/",
                    Color = "light",
                    Image = "people-outline",
                    Group = "A"
                });
            menuItems.Add(new MenuItem
                {
                    Caption = "Information",
                    Uri = "/Information",
                    Color = "default",
                    Image = "information-circle-outline",
                    Group = "A"
                });
            menuItems.Add(new MenuItem
                {
                    Caption = "Export Data",
                    Uri = "/Export",
                    Color = "default",
                    Image = "download-outline",
                    Group = "A"
                });
            menuItems.Add(new MenuItem
                {
                    Caption = "About",
                    Uri = "/About",
                    Color = "default",
                    Image = "help-circle-outline",
                    Group = "A"
                });
            menuItems.Add(new MenuItem
            {
                Caption = "Settings",
                Uri = "/Settings",
                Color = "default",
                Image = "settings-outline",
                Group = "B"
            });
        }
        else
        {
            menuItems.Add(new MenuItem
                {
                    Caption = "Information",
                    Uri = "/Information",
                    Color = "light",
                    Image = "information-circle-outline",
                    Group = "A"
                });   
        }
    }

    void SetHighlight(string uri)
    {
        foreach (var oMenuItem in menuItems)
        {
            oMenuItem.Color = uri.ToLower() == oMenuItem.Uri.ToLower() ? "light" : "default";
        } 
    }

    void LocationChanged(object? sender, LocationChangedEventArgs e)
    {
        string newUri = $"/{navigationManager.ToBaseRelativePath(e.Location)}";
        if (menuItems.Any(m => m.Uri.ToLower() == newUri.ToLower()))
        {
            SetHighlight(newUri);
        }
        StateHasChanged();
    }

    class MenuItem
    {
        public string Caption { get; set; } = string.Empty;
        public string Uri { get; set; } = string.Empty;
        public string Color { get; set; } = string.Empty;
        public string Image { get; set; } = string.Empty;
        public string Group { get; set; } = string.Empty;
    }

    public void Dispose()
    {
        navigationManager.LocationChanged -= LocationChanged;
    }
}
