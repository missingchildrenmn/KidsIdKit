@inherits InputBase<bool>
@inject IJSRuntime JSRuntime

<ion-toggle id="@Id.ToString()" checked="@CurrentValue" justify="end"></ion-toggle>

<script>
    function setBoolEventhandler(objRef, id) {
        const boolElement = document.getElementById(id);
        console.log(id);
        boolElement.addEventListener("ionChange", ({ detail }) => {
            objRef.invokeMethodAsync('UpdateBool', detail.checked);
        });
    }
</script>
