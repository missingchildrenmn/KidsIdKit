@page "/"

@using KidsIdKit.Core.Services
@inject IFamilyStateService FamilyState
@inject NavigationManager NavigationManager

@using Microsoft.AspNetCore.Components.QuickGrid

<ion-header>
    <ion-toolbar color="primary">
        <ion-buttons slot="start">
            <ion-button style="--box-shadow: none">
                <ion-menu-button></ion-menu-button>
            </ion-button>
        </ion-buttons>
        <ion-title>Kids</ion-title>
    </ion-toolbar>
</ion-header>
<ion-content class="ion-padding">

@if (!string.IsNullOrEmpty(errorMessage))
{
    <ion-card color="danger">
        <ion-card-content>
            <ion-text color="light">
                @errorMessage
            </ion-text>
        </ion-card-content>
    </ion-card>
}

@if (data == null || FamilyState.Family == null)
{
    <ion-card>
        <ion-card-content class="ion-text-center">
            <ion-spinner></ion-spinner>
            <p>Loading data...</p>
        </ion-card-content>
    </ion-card>
}
else if (FamilyState.Family.Children.Count == 0)
{
    <ion-text>
        <p>On this page, you can add new kids:</p>
    </ion-text>
}
else
{
        <ion-text color="medium">
            <p>On this page, you can view/edit existing kids as well as add new kids:</p>
        </ion-text>

        <ion-text><h2>@EditExistingChildText</h2></ion-text>
        <ion-list lines="none">
            @foreach (var context in data)
            {
            <ion-card button @onclick="@(() => NavigateToEdit(context))" style="cursor: pointer; margin-bottom: 1rem;">
                <ion-card-header>
                    <ion-card-title>@context.ChildDetails.FullName</ion-card-title>
                    <ion-card-subtitle>Age @context.ChildDetails.Age (@context.ChildDetails.Birthday.ToString("d"))</ion-card-subtitle>
                </ion-card-header>
                <ion-card-content>
                    @if (!string.IsNullOrWhiteSpace(context.ChildDetails.Names))
                    {
                        <ion-text color="medium">
                            <p><em>@context.ChildDetails.Names</em></p>
                        </ion-text>
                    }

                    @if (!string.IsNullOrWhiteSpace(context.ChildDetails.Photo.ImageSource))
                    {
                        <div style="text-align: center; margin-top: 1rem;">
                            <ion-img src="@context.ChildDetails.Photo.ImageSource" 
                            alt="Photo of @context.ChildDetails.FullName"
                            style="max-width: 200px; height: auto;"></ion-img>
                        </div>
                    }
                </ion-card-content>
                <div style="margin-top: 1rem; text-align: right;">
                    <ion-button fill="clear"
                                color="danger"
                                title="Remove @context.ChildDetails.GivenName"
                                @onclick="@((e) => ShowAlert(context))"
                                @onclick:stopPropagation="true">
                        <ion-icon slot="icon-only" name="trash"></ion-icon>
                    </ion-button>
                </div>
            </ion-card>
            }
        </ion-list>
        <McmAlert Header=@AlertTitle Message=@AlertMessage ConfirmPrompt="Yes" CancelPrompt="No" Show="@AlertShow" StateInformation="@AlertStateInformation" AlertClosed="async ((McmAlert.AlertAction action, string stateInformation) response) => await DeleteResponse(response.stateInformation, response.action)" />

    @if (LastDateTimeAnyChildWasUpdatedAsync != DateTime.MinValue)
    {
        <ion-card color="light">
            <ion-card-content>
                <ion-text color="dark">
                    <p><strong>Last edit of any child:</strong> @LastDateTimeAnyChildWasUpdatedAsync.ToString("g")</p>
                </ion-text>
            </ion-card-content>
        </ion-card>
    }

    @if (UserNeedsToUpdateInfo)
    {

        <ion-text color="dark">
            <p>The last time you updated any child info was @LastDateTimeAnyChildWasUpdatedAsync. We encourage you to update details with the most up to date info.</p>
        </ion-text>
    }
}

        <ion-button expand="block" color="secondary" @onclick="@(() => NavigationManager.NavigateTo("/Child/-1"))">
            <ion-icon slot="start" name="add-circle"></ion-icon>
            Add a new child
        </ion-button>
</ion-content>