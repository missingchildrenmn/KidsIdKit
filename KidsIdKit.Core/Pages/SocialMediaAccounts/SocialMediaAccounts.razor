@page "/childSocialMediaAccounts/{Id:int}"

@using Microsoft.AspNetCore.Components.QuickGrid;
@using KidsIdKit.Core.Data
@using KidsIdKit.Core.Services

@inject IFamilyStateService FamilyState
@inject NavigationManager NavigationManager

@inherits PageBase

@{
base.BuildRenderTree(__builder);
}

<ion-content class="ion-padding">

@if (CurrentChild == null || SocialMediaAccountObjects == null)
{
    <ion-card>
        <ion-card-content class="ion-text-center">
            <ion-spinner></ion-spinner>
            <p>Loading...</p>
        </ion-card-content>
    </ion-card>
}
else
{
    <ion-card>
        <ion-card-header>
            <ion-card-title>@CurrentChild.FullName</ion-card-title>
        </ion-card-header>
    </ion-card>

    @if (SocialMediaAccountObjects != null && SocialMediaAccountObjects.Count() > 0)
    {
        @foreach (var socialMediaAccount in SocialMediaAccountObjects)
        {
    <ion-card button @onclick="@(() => NavigateToSocialMediaAccountEdit(Id, socialMediaAccount.Id))" style="cursor: pointer; margin-bottom: 1rem;">
        <ion-card-content>
            <ion-grid>
                <ion-row>
                    <ion-col size="4" size-sm="3">
                        <ion-label>Platform:</ion-label>
                    </ion-col>
                    <ion-col>
                        <ion-text>
                            <p>@socialMediaAccount.Platform</p>
                        </ion-text>
                    </ion-col>
                </ion-row>
                <ion-row>
                    <ion-col size="4" size-sm="3">
                        <ion-label>Username:</ion-label>
                    </ion-col>
                    <ion-col>
                        <ion-text>
                            <p>@socialMediaAccount.UserName</p>
                        </ion-text>
                    </ion-col>
                </ion-row>
                <ion-row>
                    <ion-col size="4" size-sm="3">
                        <ion-label>Password:</ion-label>
                    </ion-col>
                    <ion-col style="display: flex; align-items: center;">
                        @if (passwordVisibilityManager.IsPasswordVisible(socialMediaAccount.Id))
                        {
                            <ion-text>
                                <span>@socialMediaAccount.Password</span>
                            </ion-text>
                            <ion-button fill="clear" size="small" @onclick="() => passwordVisibilityManager.HidePassword(socialMediaAccount.Id)" title="Hide password" @onclick:stopPropagation="true">
                                <ion-icon slot="icon-only" name="eye-off"></ion-icon>
                            </ion-button>
                        }
                        else
                        {
                            <ion-text>
                                <span>••••••••</span>
                            </ion-text>
                            <ion-button fill="clear" size="small" @onclick="() => passwordVisibilityManager.ShowPassword(socialMediaAccount.Id)" title="Show password" @onclick:stopPropagation="true">
                                <ion-icon slot="icon-only" name="eye"></ion-icon>
                            </ion-button>
                        }
                    </ion-col>
                </ion-row>
            </ion-grid>
        </ion-card-content>
        <div style="margin-top: 1rem; text-align: right;">
            <ion-button fill="clear" color="danger" @onclick="() => ShowAlert(socialMediaAccount)" title="Delete" @onclick:stopPropagation="true">
                <ion-icon slot="icon-only" name="trash"></ion-icon>
            </ion-button>
        </div>
    </ion-card>
        }

        @if (passwordVisibilityManager.VisiblePasswordCount > 0)
        {
    <ion-button expand="block" color="secondary" @onclick="() => passwordVisibilityManager.HideAllPasswords()">
        <ion-icon slot="start" name="eye-off"></ion-icon>
        Hide All Passwords
    </ion-button>
        }
    }

    <McmAlert Header=@AlertTitle Message=@AlertMessage ConfirmPrompt="Yes" CancelPrompt="No" Show="@AlertShow" StateInformation="@AlertStateInformation" AlertClosed="async ((McmAlert.AlertAction action, string stateInformation) response) => await DeleteResponse(response.stateInformation, response.action)" />
    <div class="ion-padding">
        <ion-button expand="block" color="secondary" @onclick="@(() => NavigationManager.NavigateTo($"/SocialMediaAccount/{Id}/-1"))">
            <ion-icon slot="start" name="add-circle"></ion-icon>
            Add Social Media Account
        </ion-button>
    </div>
}
</ion-content>
