@page "/childFamilyMembers/{id:int}"

@using KidsIdKit.Core.Data
@using KidsIdKit.Core.Services

@inject IFamilyStateService FamilyState
@inject NavigationManager NavigationManager

@inherits PageBase

@{
    base.BuildRenderTree(__builder);
}

<ion-content class="ion-padding">
@if (CurrentChild == null || Family == null)
{
    <ion-card>
        <ion-card-content class="ion-text-center">
            <ion-spinner></ion-spinner>
            <p>Loading...</p>
        </ion-card-content>
    </ion-card>
}
else
{
    <ion-card>
        <ion-card-header>
            <ion-card-title>@CurrentChild.FullName</ion-card-title>
        </ion-card-header>
    </ion-card>

    @if (Family != null && Family.Count() > 0)
    {
        @foreach (var person in Family)
        {
    <ion-card button @onclick="@(() => NavigateToFamilyMemberEdit(Id, person.Id))" style="cursor: pointer; margin-bottom: 1rem;">
        <ion-card-content>
            <ion-grid>
                <ion-row>
                    <ion-col size="4" size-sm="3">
                        <ion-label>Name:</ion-label>
                    </ion-col>
                    <ion-col>
                        <ion-text>
                            <p>@person.GivenName @person.FamilyName</p>
                        </ion-text>
                    </ion-col>
                </ion-row>
                <ion-row>
                    <ion-col size="4" size-sm="3">
                        <ion-label>Phone:</ion-label>
                    </ion-col>
                    <ion-col>
                        <ion-text>
                            <p>@person.PhoneNumber</p>
                        </ion-text>
                    </ion-col>
                </ion-row>
                <ion-row>
                    <ion-col size="4" size-sm="3">
                        <ion-label>Address:</ion-label>
                    </ion-col>
                    <ion-col>
                        <ion-text>
                            <p>@person.Address</p>
                        </ion-text>
                    </ion-col>
                </ion-row>
                <ion-row>
                    <ion-col size="4" size-sm="3">
                        <ion-label>Relation:</ion-label>
                    </ion-col>
                    <ion-col>
                        <ion-text>
                            <p>@person.Relation</p>
                        </ion-text>
                    </ion-col>
                </ion-row>
            </ion-grid>
        </ion-card-content>
        <div style="margin-top: 1rem; text-align: right;">
            <ion-button fill="clear" color="danger" @onclick="() => ShowAlert(person)" title="Delete" @onclick:stopPropagation="true">
                <ion-icon slot="icon-only" name="trash"></ion-icon>
            </ion-button>
        </div>
    </ion-card>
        }
    }

    <McmAlert Header=@AlertTitle Message=@AlertMessage ConfirmPrompt="Yes" CancelPrompt="No" Show="@AlertShow" StateInformation="@AlertStateInformation" AlertClosed="async ((McmAlert.AlertAction action, string stateInformation) response) => await DeleteResponse(response.stateInformation, response.action)" />
    <div class="ion-padding">
        <ion-button expand="block" color="success" @onclick="@(() => NavigationManager.NavigateTo($"/Family/{Id}/-1"))">
            <ion-icon slot="start" name="add-circle"></ion-icon>
            Add family member
        </ion-button>
    </div>
}
</ion-content>