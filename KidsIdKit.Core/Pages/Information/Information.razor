@page "/Information"

<ion-header>
    <ion-toolbar color="primary">
        <ion-button slot="start" style="--box-shadow: none">
            <ion-menu-button></ion-menu-button>
        </ion-button>
        <ion-title>Information</ion-title>
    </ion-toolbar>
</ion-header>
<ion-content class="ion-padding">
    <ion-card>
        <ion-card-header>
            <ion-card-title>Information</ion-card-title>
        </ion-card-header>
        <ion-card-content>
            <ion-text color="medium">
                <p>
                    Helpful links to resources that parents can use to help keep your kids safe.
                </p>
            </ion-text>
        </ion-card-content>
    </ion-card>

    <ion-list>
        @foreach (var link in links)
        {
            <ion-item button href="/Information/@link.Href">
                <ion-label>@link.Text</ion-label>
                <ion-icon slot="end" name="chevron-forward-outline"></ion-icon>
            </ion-item>
        }
    </ion-list>
</ion-content>

@code {
    private List<LinkItem> links = new List<LinkItem>
    {
        new LinkItem { Href = "abduction", Text = "Abductions" },
        new LinkItem { Href = "aboutmcm", Text = "About Missing Children Minnesota" },
        new LinkItem { Href = "amberalert", Text = "AMBER Alerts" },
        new LinkItem { Href = "disasterpreparation", Text = "Disaster Preparation" },
        new LinkItem { Href = "dna", Text = "DNA" },
        new LinkItem { Href = "international", Text = "International Child Abduction" },
        new LinkItem { Href = "missing", Text = "In the Event of a Missing Child" },
        new LinkItem { Href = "runaway", Text = "Definition of a Runaway Youth" },
        new LinkItem { Href = "safety", Text = "Safer Kids Know" }
    };

    public class LinkItem
    {
        public string Href { get; set; } = string.Empty;
        public string Text { get; set; } = string.Empty;
    }
}